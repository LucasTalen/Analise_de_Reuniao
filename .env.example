# Backend (Flask)
SECRET_KEY=troque_por_um_segredo_forte
KEY_ENCRYPTION_MASTER_KEY=gere_uma_chave_fernet_base64
DATABASE_PATH=app.db
ALEMBIC_HEAD_REVISION=20260312_0001
# 0 = backend apenas API (recomendado em dev com Vite na 5173)
# 1 = backend tambem serve o frontend build (uso mais comum em producao)
SERVE_FRONTEND_FROM_FLASK=0
UPLOAD_FOLDER=uploads
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=meeting_analysis
MAX_FILE_SIZE_MB=25
MAX_VIDEO_DURATION_SECONDS=7200
ALLOWED_VIDEO_EXTENSIONS=mp4,avi,mov,mkv
OPENAI_CHAT_MODEL=gpt-4.1-nano
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_API_BASE_URL=https://api.openai.com/v1
# Limite maximo aceito pelo provedor para cada parte de transcricao.
# Valores acima de 25 nao sao aceitos pela OpenAI.
OPENAI_TRANSCRIPTION_PROVIDER_MAX_FILE_SIZE_MB=25
OPENAI_VALIDATE_TIMEOUT_SECONDS=15
OPENAI_CHAT_TIMEOUT_SECONDS=90
OPENAI_TRANSCRIPTION_TIMEOUT_SECONDS=120
AUTH_TOKEN_TTL_SECONDS=86400
PASSWORD_HASH_METHOD=scrypt
PASSWORD_SALT_LENGTH=16
PASSWORD_MIN_LENGTH=10
# Opcional: segredo extra para endurecer hashes (pepper)
PASSWORD_PEPPER=
ANALYSIS_SESSION_TTL_MINUTES=180
MAX_HISTORY_MESSAGES=12
RATE_LIMIT_UPLOAD_PER_MIN=10
RATE_LIMIT_ANALYZE_PER_MIN=5
RATE_LIMIT_FOLLOWUP_PER_MIN=30
RATE_LIMIT_AUTH_REGISTER_PER_MIN=10
RATE_LIMIT_AUTH_LOGIN_PER_MIN=15
USAGE_DASHBOARD_DEFAULT_DAYS=7
USAGE_DASHBOARD_MAX_DAYS=90
INTERNAL_ADMIN_KEY=
# Defina custos por 1K tokens se quiser estimar governanca (opcional)
OPENAI_CHAT_INPUT_COST_PER_1K=0
OPENAI_CHAT_OUTPUT_COST_PER_1K=0
